generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CalendarEvent {
  id        String   @id @default(uuid())
  title     String
  notes     String?
  date      DateTime
  time      String
  endTime   String?
  createdBy String
  status    String   @default("pending")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
